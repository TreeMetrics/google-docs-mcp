# Copy this file to .env and fill in values.
# .env is gitignored.

# --- Transport ---
# httpStream = remote/HTTP mode (required for Docker + AWS)
# stdio = local CLI use with Claude Desktop etc.
MCP_TRANSPORT=httpStream

# --- Public URL ---
# Where this server is reachable from the outside. For local Docker use
# http://localhost:8080. For AWS, set the ALB/App Runner public URL.
# MUST match the authorised redirect URI in your Google OAuth client
# (redirect URI = ${BASE_URL}/oauth/callback).
BASE_URL=http://localhost:8088

# --- Google OAuth (Web application type, not Desktop) ---
# Create at https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Access control (optional) ---
# Comma-separated list of Google Workspace domains allowed to sign in.
# Leave empty to allow any Google account.
ALLOWED_DOMAINS=treemetrics.com

# --- HTTP ---
PORT=8080

# --- Session persistence ---
# Fixed key so issued MCP tokens survive container restarts.
# Generate with: openssl rand -hex 32
JWT_SIGNING_KEY=
# Optional; encrypts refresh tokens at rest. Generate the same way.
TOKEN_ENCRYPTION_KEY=

# Token store: unset = in-memory (sessions die on restart).
# firestore is supported upstream but needs GCP. AWS-native adapter TBD.
# TOKEN_STORE=firestore
# GCLOUD_PROJECT=
